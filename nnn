body {
    font-family: Arial;
    margin: 0;
    padding: 0;
}

header, footer {
    background: #333;
    color: white;
    text-align: center;
    padding: 15px;
}

nav {
    background: #555;
    text-align: center;
    padding: 10px;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
}

main {
    padding: 20px;
}

img {
    width: 100%;
    max-width: 400px;
    display: block;
    margin: 10px 0;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

figure {
